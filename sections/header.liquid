<!-- Premium Glassmorphic Header Component -->
<style>
  .section-header,
  .shopify-section-group-header-group {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    height: 0 !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
    pointer-events: none !important;
  }
</style>

<div 
  class="custom-glass-header-wrapper color-{{ section.settings.color_scheme }}" 
  id="custom-glass-header-wrapper" 
  style="--glass-opacity: {{ section.settings.glass_opacity | divided_by: 100.0 }}; --glass-radius: {{ section.settings.glass_radius }}px;"
>
  <header class="custom-glass-header">
    
    <!-- LEFT: Hamburger Menu Circle Button -->
    <div class="custom-header-left">
      <button class="header-hamburger-btn" aria-label="Menu" id="header-hamburger-menu-btn">
        <svg width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 2H18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M0 10H18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- MIDDLE: Logo -->
    <div class="custom-header-center">
      <a href="{{ routes.root_url }}" class="header-logo-link">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = section.settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {{
            settings.logo
            | image_url: width: 600
            | image_tag:
              class: 'header-logo-img',
              height: logo_height,
              width: section.settings.logo_width,
              alt: logo_alt,
              preload: true
          }}
        {%- else -%}
          <span class="header-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- RIGHT: Search, Profile, Cart -->
    <div class="custom-header-right">
      <!-- Search Icon Button -->
      <a href="{{ routes.search_url }}" class="header-icon-btn" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <!-- Profile Icon Button -->
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header-icon-btn" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {%- endif -%}

      <!-- Cart Dynamic Pill Badge -->
      <a href="{{ routes.cart_url }}" class="header-cart-pill" id="cart-icon-bubble">
        <svg class="icon icon-cart" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="header-cart-text">Cart (<span id="cart-count-value">{{ cart.item_count }}</span>)</span>
      </a>
    </div>
    
  </header>
</div>

{% stylesheet %}
  /* Collapsing Shopify Section containers to start content at y=0 */
  .section-header,
  .shopify-section-group-header-group {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    height: 0 !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
    pointer-events: none !important;
  }

  /* Custom Glassmorphic Header CSS */
  .custom-glass-header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 1000;
    padding: 0;
    box-sizing: border-box;
    pointer-events: none; /* Let clicks pass through margins */
    background: transparent !important;
    transition: padding 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .custom-glass-header {
    pointer-events: auto; /* Enable clicks on header content */
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
    height: 72px;
    padding: 0 32px;
    box-sizing: border-box;
    background: rgba(var(--color-background), var(--glass-opacity));
    backdrop-filter: blur(20px) saturate(190%);
    -webkit-backdrop-filter: blur(20px) saturate(190%);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: border-radius 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                margin 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Scrolled Floating State */
  .custom-glass-header-wrapper.is-scrolled {
    padding: 16px 24px 0 24px;
  }

  .custom-glass-header-wrapper.is-scrolled .custom-glass-header {
    border-radius: var(--glass-radius);
    border: 1px solid rgba(var(--color-foreground), 0.15);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    height: 64px; /* Slightly slimmer when floating */
  }

  /* Layout alignment */
  .custom-header-left {
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  .custom-header-center {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .custom-header-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 20px;
  }

  /* Hamburger button */
  .header-hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    border: 1px solid rgba(var(--color-foreground), 0.08);
    cursor: pointer;
    outline: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header-hamburger-btn:hover {
    background: rgba(var(--color-foreground), 0.12);
    border-color: rgba(var(--color-foreground), 0.15);
    transform: scale(1.05);
  }

  .header-hamburger-btn:active {
    transform: scale(0.95);
  }

  /* Logo image & text styling */
  .header-logo-link {
    display: inline-flex;
    text-decoration: none;
    color: rgb(var(--color-foreground));
  }

  .header-logo-img {
    display: block;
    max-width: 100%;
    height: auto;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header-logo-link:hover .header-logo-img {
    transform: scale(1.03);
  }

  .header-logo-text {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: 2.2rem;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
  }

  /* Plain icon buttons (Search, Profile) */
  .header-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: transparent;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header-icon-btn:hover {
    background: rgba(var(--color-foreground), 0.06);
    transform: scale(1.1);
  }

  .header-icon-btn:active {
    transform: scale(0.92);
  }

  /* Cart dynamic pill button */
  .header-cart-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 9999px;
    background: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    text-decoration: none;
    font-size: 1.4rem;
    font-weight: 500;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header-cart-pill:hover {
    background: rgba(var(--color-foreground), 0.12);
    border-color: rgba(var(--color-foreground), 0.15);
    transform: scale(1.05);
  }

  .header-cart-pill:active {
    transform: scale(0.96);
  }

  .header-cart-pill svg {
    flex-shrink: 0;
  }

  /* Mobile responsive fixes */
  @media screen and (max-width: 749px) {
    .custom-glass-header {
      padding: 0 16px;
      height: 64px;
    }
    
    .custom-glass-header-wrapper.is-scrolled {
      padding: 10px 12px 0 12px;
    }
    
    .custom-glass-header-wrapper.is-scrolled .custom-glass-header {
      height: 56px;
    }
    
    .custom-header-right {
      gap: 10px;
    }
    
    .header-cart-pill {
      padding: 8px 12px;
    }
    
    .header-cart-text {
      font-size: 1.2rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const headerWrapper = document.getElementById('custom-glass-header-wrapper');
    if (!headerWrapper) return;

    const threshold = 10; // Scroll threshold in pixels

    function checkScroll() {
      const scrollY = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollY > threshold) {
        headerWrapper.classList.add('is-scrolled');
      } else {
        headerWrapper.classList.remove('is-scrolled');
      }
    }

    // Run check on load in case the page is already scrolled
    checkScroll();

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          checkScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Custom Glass Header",
  "class": "section-header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "range",
      "id": "glass_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%",
      "label": "Glass Opacity"
    },
    {
      "type": "range",
      "id": "glass_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px",
      "label": "Scrolled Border Radius"
    }
  ]
}
{% endschema %}
