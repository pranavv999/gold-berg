<!-- Premium Glassmorphic Header Component -->
<style>
  /* Collapsing Shopify Section containers to start content at y=0 */
  .section-header,
  .shopify-section-group-header-group {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    height: 0 !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
    pointer-events: none !important;
  }

  /* Custom Glassmorphic Header CSS */
  .custom-glass-header-wrapper {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    z-index: 1000 !important;
    padding: 0 !important;
    box-sizing: border-box !important;
    pointer-events: none !important;
    background: transparent !important;
    transition: padding 0.5s cubic-bezier(0.16, 1, 0.3, 1) !important;
    --glass-opacity: {{ section.settings.glass_opacity | divided_by: 100.0 }};
    --glass-radius: {{ section.settings.glass_radius }}px;
  }

  .custom-glass-header {
    pointer-events: auto !important;
    display: grid !important;
    grid-template-columns: 1fr auto 1fr !important;
    align-items: center !important;
    width: 100% !important;
    height: 72px !important;
    padding: 0 32px !important;
    box-sizing: border-box !important;
    background: rgba(var(--color-background), var(--glass-opacity)) !important;
    backdrop-filter: blur(20px) saturate(190%) !important;
    -webkit-backdrop-filter: blur(20px) saturate(190%) !important;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08) !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02) !important;
    transition: border-radius 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                margin 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                height 0.5s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  /* Scrolled Floating State */
  .custom-glass-header-wrapper.is-scrolled {
    padding: 16px 24px 0 24px !important;
  }

  .custom-glass-header-wrapper.is-scrolled .custom-glass-header {
    border-radius: var(--glass-radius) !important;
    border: 1px solid rgba(var(--color-foreground), 0.15) !important;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08) !important;
    height: 64px !important;
  }

  /* Layout alignment */
  .custom-header-left {
    display: flex !important;
    justify-content: flex-start !important;
    align-items: center !important;
  }

  .custom-header-center {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
  }

  .custom-header-right {
    display: flex !important;
    justify-content: flex-end !important;
    align-items: center !important;
    gap: 20px !important;
  }

  /* Hamburger button */
  .header-hamburger-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 44px !important;
    height: 44px !important;
    border-radius: 50% !important;
    background: rgba(var(--color-foreground), 0.06) !important;
    color: rgb(var(--color-foreground)) !important;
    border: 1px solid rgba(var(--color-foreground), 0.08) !important;
    cursor: pointer !important;
    outline: none !important;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .header-hamburger-btn:hover {
    background: rgba(var(--color-foreground), 0.12) !important;
    border-color: rgba(var(--color-foreground), 0.15) !important;
    transform: scale(1.05) !important;
  }

  .header-hamburger-btn:active {
    transform: scale(0.95) !important;
  }

  /* Logo image & text styling */
  .header-logo-link {
    display: inline-flex !important;
    text-decoration: none !important;
    color: rgb(var(--color-foreground)) !important;
  }

  .header-logo-img {
    display: block !important;
    max-width: 100% !important;
    height: auto !important;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .header-logo-link:hover .header-logo-img {
    transform: scale(1.03) !important;
  }

  .header-logo-text {
    font-family: var(--font-heading-family) !important;
    font-weight: var(--font-heading-weight) !important;
    font-size: 2.2rem !important;
    letter-spacing: 0.1rem !important;
    text-transform: uppercase !important;
    white-space: nowrap !important;
  }

  /* Plain icon buttons (Search, Profile) */
  .header-icon-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: rgb(var(--color-foreground)) !important;
    text-decoration: none !important;
    width: 36px !important;
    height: 36px !important;
    border-radius: 50% !important;
    background: transparent !important;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .header-icon-btn:hover {
    background: rgba(var(--color-foreground), 0.06) !important;
    transform: scale(1.1) !important;
  }

  .header-icon-btn:active {
    transform: scale(0.92) !important;
  }

  /* Cart dynamic pill button */
  .header-cart-pill {
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 10px 18px !important;
    border-radius: 9999px !important;
    background: rgba(var(--color-foreground), 0.06) !important;
    color: rgb(var(--color-foreground)) !important;
    text-decoration: none !important;
    font-size: 1.4rem !important;
    font-weight: 500 !important;
    border: 1px solid rgba(var(--color-foreground), 0.08) !important;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .header-cart-pill:hover {
    background: rgba(var(--color-foreground), 0.12) !important;
    border-color: rgba(var(--color-foreground), 0.15) !important;
    transform: scale(1.05) !important;
  }

  .header-cart-pill:active {
    transform: scale(0.96) !important;
  }

  .header-cart-pill svg {
    flex-shrink: 0 !important;
  }

  /* Visibility Helpers */
  .hide-on-desktop {
    display: none !important;
  }
  .hide-on-mobile {
    display: inline-flex !important;
  }

  /* Mobile/Tablet responsive fixes */
  @media screen and (max-width: 989px) {
    .hide-on-desktop {
      display: inline-flex !important;
    }
    .hide-on-mobile {
      display: none !important;
    }

    .custom-glass-header {
      padding: 0 16px !important;
      height: 64px !important;
    }
    
    .custom-glass-header-wrapper.is-scrolled {
      padding: 10px 12px 0 12px !important;
    }
    
    .custom-glass-header-wrapper.is-scrolled .custom-glass-header {
      height: 56px !important;
    }
    
    /* LEFT: Search aligned next to hamburger button */
    .custom-header-left {
      gap: 12px !important;
    }

    /* Remove round bubble style on hamburger button */
    .header-hamburger-btn {
      background: transparent !important;
      border: none !important;
      width: 24px !important;
      height: 24px !important;
      border-radius: 0 !important;
      padding: 0 !important;
      color: rgb(var(--color-foreground)) !important;
      box-shadow: none !important;
    }
    .header-hamburger-btn:hover {
      background: transparent !important;
      transform: none !important;
    }
    .header-hamburger-btn:active {
      transform: scale(0.92) !important;
    }

    /* RIGHT: gap adjustment */
    .custom-header-right {
      gap: 12px !important;
    }

    .header-icon-btn {
      width: 32px !important;
      height: 32px !important;
    }
    
    /* Make Cart Pill look like a flat icon button (no pill wrapper/text) */
    .header-cart-pill {
      background: transparent !important;
      border: none !important;
      border-radius: 50% !important;
      padding: 0 !important;
      width: 32px !important;
      height: 32px !important;
      justify-content: center !important;
      gap: 0 !important;
      box-shadow: none !important;
    }
    .header-cart-pill:hover {
      background: rgba(var(--color-foreground), 0.06) !important;
      transform: scale(1.1) !important;
    }
    .header-cart-pill:active {
      transform: scale(0.92) !important;
    }
    .header-cart-pill .header-cart-text {
      display: none !important;
    }

    /* Scaling Logo and Text */
    .header-logo-text {
      font-size: 1.8rem !important;
    }
    .header-logo-img {
      max-width: 120px !important;
    }
  }
</style>

<div 
  class="custom-glass-header-wrapper color-{{ section.settings.color_scheme }}" 
  id="custom-glass-header-wrapper" 
  style="--glass-opacity: {{ section.settings.glass_opacity | divided_by: 100.0 }}; --glass-radius: {{ section.settings.glass_radius }}px;"
>
  <header class="custom-glass-header">
    
    <!-- LEFT: Hamburger Menu and Search Icon (Mobile) -->
    <div class="custom-header-left">
      <button class="header-hamburger-btn" aria-label="Menu" id="header-hamburger-menu-btn">
        <svg width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 2H18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M0 10H18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      
      <!-- Search Button (Visible on Mobile only) -->
      <a href="{{ routes.search_url }}" class="header-icon-btn hide-on-desktop" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>
    </div>

    <!-- MIDDLE: Logo -->
    <div class="custom-header-center">
      <a href="{{ routes.root_url }}" class="header-logo-link">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = section.settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {{
            settings.logo
            | image_url: width: 600
            | image_tag:
              class: 'header-logo-img',
              height: logo_height,
              width: section.settings.logo_width,
              alt: logo_alt,
              preload: true
          }}
        {%- else -%}
          <span class="header-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- RIGHT: Search, Profile, Cart -->
    <div class="custom-header-right">
      <!-- Search Icon Button (Visible on Desktop only) -->
      <a href="{{ routes.search_url }}" class="header-icon-btn hide-on-mobile" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <!-- Profile Icon Button -->
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header-icon-btn" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {%- endif -%}

      <!-- Cart Dynamic Pill Badge -->
      <a href="{{ routes.cart_url }}" class="header-cart-pill" id="cart-icon-bubble">
        <svg class="icon icon-cart" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="header-cart-text">Cart (<span id="cart-count-value">{{ cart.item_count }}</span>)</span>
      </a>
    </div>
    
  </header>
</div>




{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const headerWrapper = document.getElementById('custom-glass-header-wrapper');
    if (!headerWrapper) return;

    const threshold = 10; // Scroll threshold in pixels

    function checkScroll() {
      const scrollY = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollY > threshold) {
        headerWrapper.classList.add('is-scrolled');
      } else {
        headerWrapper.classList.remove('is-scrolled');
      }
    }

    // Run check on load in case the page is already scrolled
    checkScroll();

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          checkScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Custom Glass Header",
  "class": "section-header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "range",
      "id": "glass_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%",
      "label": "Glass Opacity"
    },
    {
      "type": "range",
      "id": "glass_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px",
      "label": "Scrolled Border Radius"
    }
  ]
}
{% endschema %}
